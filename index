<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>3D Partner AI</title>
    <style>
        body { margin: 0; overflow: hidden; background-color: #e0f7fa; font-family: sans-serif; }
        
        /* ⚙️設定ボタン */
        #settings-toggle {
            position: absolute; top: 15px; right: 15px; z-index: 20;
            background: #333; color: white; border: none; border-radius: 50%;
            width: 45px; height: 45px; font-size: 24px; cursor: pointer;
            box-shadow: 0 4px 6px rgba(0,0,0,0.3); display: flex; align-items: center; justify-content: center;
        }
        
        /* 設定パネル */
        #settings-panel {
            position: absolute; top: 70px; right: 15px;
            width: 280px; max-width: 85vw; background: rgba(0, 0, 0, 0.85);
            color: white; padding: 15px; border-radius: 10px;
            box-sizing: border-box; z-index: 10; display: none;
            backdrop-filter: blur(5px); max-height: 80vh; overflow-y: auto;
        }
        
        h3 { margin-top: 0; font-size: 14px; border-bottom: 1px solid #555; padding-bottom: 5px; color: #4CAF50; }
        .control-group { margin-bottom: 15px; }
        .control-group label { display: block; font-size: 12px; margin-bottom: 5px; }
        input[type="password"], input[type="text"] { width: 100%; box-sizing: border-box; padding: 8px; border-radius: 5px; border: none; }
        input[type="file"] { width: 100%; font-size: 12px; background: #fff; color: #000; padding: 5px; border-radius: 5px; box-sizing: border-box; }
        button.action-btn { width: 100%; padding: 10px; background: #2196F3; color: white; border: none; border-radius: 5px; cursor: pointer; font-weight: bold; margin-top: 5px; }
        button.action-btn:active { background: #1976D2; }

        /* チャットUI */
        #chat-container {
            position: absolute; bottom: 0; left: 0; width: 100%;
            background: linear-gradient(to top, rgba(255,255,255,1) 60%, rgba(255,255,255,0));
            padding: 20px 10px 10px 10px; box-sizing: border-box; z-index: 5;
            display: flex; flex-direction: column; gap: 10px; pointer-events: none;
        }
        
        #chat-history {
            max-height: 25vh; overflow-y: auto; pointer-events: auto;
            display: flex; flex-direction: column; gap: 10px; padding-bottom: 10px;
        }
        
        .msg { max-width: 80%; padding: 10px 15px; border-radius: 20px; font-size: 14px; line-height: 1.4; word-wrap: break-word; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .msg.user { align-self: flex-end; background: #E3F2FD; border-bottom-right-radius: 0; }
        .msg.bot { align-self: flex-start; background: #ffffff; border: 1px solid #ddd; border-bottom-left-radius: 0; }

        #quick-replies { display: flex; gap: 8px; overflow-x: auto; pointer-events: auto; padding-bottom: 5px; }
        .qr-btn { padding: 8px 15px; background: #F48FB1; color: white; border: none; border-radius: 20px; font-size: 13px; font-weight: bold; cursor: pointer; white-space: nowrap; flex-shrink: 0; }
        .qr-btn:active { transform: scale(0.95); }

        #input-area { display: flex; gap: 10px; pointer-events: auto; }
        #chat-input { flex: 1; padding: 12px; border: 2px solid #ddd; border-radius: 25px; outline: none; font-size: 14px; }
        #chat-input:focus { border-color: #2196F3; }
        #send-btn { background: #2196F3; color: white; border: none; border-radius: 50%; width: 45px; height: 45px; font-size: 18px; cursor: pointer; display: flex; align-items: center; justify-content: center; }

        #loading-overlay {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5); color: white; display: none;
            align-items: center; justify-content: center; z-index: 30; font-weight: bold;
        }
    </style>
</head>
<body>

    <div id="loading-overlay">処理中...</div>

    <button id="settings-toggle" onclick="toggleSettings()">⚙️</button>

    <div id="settings-panel">
        <h3>🔑 Gemini API キー</h3>
        <div class="control-group">
            <input type="password" id="api-key" placeholder="AI Studioで取得したキー">
        </div>

        <h3>📂 アバター (VRM) 読込</h3>
        <div class="control-group">
            <input type="file" id="vrm-file" accept=".vrm" />
        </div>

        <h3>📝 キャラ設定 (JSON) 読込</h3>
        <div class="control-group">
            <input type="file" id="json-file" accept=".json" />
        </div>

        <h3>💾 記憶・ログのエクスポート</h3>
        <div class="control-group">
            <button class="action-btn" onclick="exportData()">会話ログ・記憶をダウンロード</button>
            <button class="action-btn" onclick="clearMemory()" style="background:#f44336; margin-top:10px;">記憶をすべてリセット</button>
        </div>
    </div>

    <div id="chat-container">
        <div id="chat-history"></div>
        <div id="quick-replies"></div>
        <div id="input-area">
            <input type="text" id="chat-input" placeholder="メッセージを入力...">
            <button id="send-btn">➤</button>
        </div>
    </div>

    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.167.0/build/three.module.js",
                "three/addons/": "https://unpkg.com/three@0.167.0/examples/jsm/",
                "@pixiv/three-vrm": "https://unpkg.com/@pixiv/three-vrm@3.2.0/lib/three-vrm.module.js"
            }
        }
    </script>

    <script type="module">
        import * as THREE from 'three';
        import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
        import { VRMLoaderPlugin, VRMUtils } from '@pixiv/three-vrm';

        // ==========================================
        // 1. データ管理 (LocalStorage)
        // ==========================================
        let chatHistory = JSON.parse(localStorage.getItem('vrm_chatHistory')) || [];
        let relationMemory = JSON.parse(localStorage.getItem('vrm_relationMemory')) || {};
        let characterSettings = JSON.parse(localStorage.getItem('vrm_characterSettings')) || null;
        
        const apiKeyInput = document.getElementById('api-key');
        apiKeyInput.value = localStorage.getItem('vrm_apiKey') || '';
        apiKeyInput.addEventListener('change', (e) => localStorage.setItem('vrm_apiKey', e.target.value));

        // ==========================================
        // 2. Three.js & VRM セットアップ
        // ==========================================
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(30, window.innerWidth / window.innerHeight, 0.1, 20);
        camera.position.set(0, 1.4, 4);

        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(window.devicePixelRatio);
        document.body.appendChild(renderer.domElement);

        const controls = new OrbitControls(camera, renderer.domElement);
        controls.target.set(0, 1.0, 0);
        controls.update();

        const light = new THREE.DirectionalLight(0xffffff, 1.5);
        light.position.set(1, 1, 1).normalize();
        scene.add(light);
        scene.add(new THREE.AmbientLight(0xffffff, 0.6));

        let currentVrm = null;
        let currentGesture = 'listening'; // デフォルトは傾聴
        let gestureTimer = 0; // 一時的なジェスチャーの管理用
        const clock = new THREE.Clock();

        const loader = new GLTFLoader();
        loader.register((parser) => new VRMLoaderPlugin(parser));

        // VRM読み込み
        document.getElementById('vrm-file').addEventListener('change', (event) => {
            const file = event.target.files[0];
            if (!file) return;
            document.getElementById('loading-overlay').style.display = 'flex';
            const blobUrl = URL.createObjectURL(file);
            loader.load(blobUrl, (gltf) => {
                if (currentVrm) scene.remove(currentVrm.scene);
                const vrm = gltf.userData.vrm;
                scene.add(vrm.scene);
                currentVrm = vrm;
                vrm.scene.rotation.y = Math.PI;
                document.getElementById('loading-overlay').style.display = 'none';
                document.getElementById('settings-panel').style.display = 'none';
                URL.revokeObjectURL(blobUrl);
            });
        });

        // キャラ設定JSON読み込み
        document.getElementById('json-file').addEventListener('change', (event) => {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = (e) => {
                try {
                    characterSettings = JSON.parse(e.target.result);
                    localStorage.setItem('vrm_characterSettings', JSON.stringify(characterSettings));
                    alert('キャラクター設定を読み込みました！');
                } catch (err) {
                    alert('JSONファイルの解析に失敗しました。形式を確認してください。');
                }
            };
            reader.readAsText(file);
        });

        // ==========================================
        // 3. アニメーション・アルゴリズム
        // ==========================================
        function setBasePose(humanoid) {
            // 基本姿勢 (少しリラックスした立ち姿)
            humanoid.getNormalizedBoneNode('leftShoulder').rotation.z = 0.1;
            humanoid.getNormalizedBoneNode('rightShoulder').rotation.z = -0.1;
            humanoid.getNormalizedBoneNode('leftUpperArm').rotation.z = 1.1;
            humanoid.getNormalizedBoneNode('rightUpperArm').rotation.z = -1.1;
            humanoid.getNormalizedBoneNode('leftLowerArm').rotation.z = 0.1;
            humanoid.getNormalizedBoneNode('rightLowerArm').rotation.z = -0.1;
        }

        function updateAnimation(deltaTime, elapsedTime) {
            if (!currentVrm) return;
            const humanoid = currentVrm.humanoid;
            const expressions = currentVrm.expressionManager;

            humanoid.resetPose();
            setBasePose(humanoid);

            // 1. オート動作 (呼吸とわずかな揺れ)
            humanoid.getNormalizedBoneNode('spine').rotation.x = Math.sin(elapsedTime * 1.5) * 0.01;
            humanoid.getNormalizedBoneNode('neck').rotation.y = Math.sin(elapsedTime * 0.3) * 0.03;

            // 2. ジェスチャー処理 (時間経過で元に戻る)
            if (gestureTimer > 0) {
                gestureTimer -= deltaTime;
                if (gestureTimer <= 0) {
                    currentGesture = 'listening'; // 時間切れで傾聴モードへ戻る
                    expressions.setValue('happy', 0);
                    expressions.setValue('angry', 0);
                    expressions.setValue('sad', 0);
                    expressions.setValue('neutral', 1);
                }
            }

            // 大げさなリアクションのオーバーライド
            switch (currentGesture) {
                case 'nod': // 大きく頷く
                    humanoid.getNormalizedBoneNode('neck').rotation.x = Math.sin(elapsedTime * 10) * 0.2;
                    break;
                case 'shake_head': // 首を振る
                    humanoid.getNormalizedBoneNode('neck').rotation.y = Math.sin(elapsedTime * 10) * 0.3;
                    break;
                case 'joy': // 喜ぶ（バンザイ）
                    humanoid.getNormalizedBoneNode('spine').rotation.x -= 0.1;
                    humanoid.getNormalizedBoneNode('leftUpperArm').rotation.z = 2.5;
                    humanoid.getNormalizedBoneNode('rightUpperArm').rotation.z = -2.5;
                    break;
                case 'angry': // 怒る
                    humanoid.getNormalizedBoneNode('spine').rotation.x = 0.15;
                    humanoid.getNormalizedBoneNode('leftUpperArm').rotation.x = -0.5;
                    humanoid.getNormalizedBoneNode('rightUpperArm').rotation.x = -0.5;
                    humanoid.getNormalizedBoneNode('leftUpperArm').rotation.z = 1.0;
                    humanoid.getNormalizedBoneNode('rightUpperArm').rotation.z = -1.0;
                    break;
                case 'sorrow': // 悲しむ
                    humanoid.getNormalizedBoneNode('spine').rotation.x = 0.2;
                    humanoid.getNormalizedBoneNode('neck').rotation.x = 0.4;
                    break;
                case 'present': // 案内する
                    humanoid.getNormalizedBoneNode('rightUpperArm').rotation.z = -1.5;
                    humanoid.getNormalizedBoneNode('rightUpperArm').rotation.x = -0.5;
                    break;
                case 'listening':
                    // 話を聞いている時の仕草（少し首を傾げる）
                    humanoid.getNormalizedBoneNode('neck').rotation.z = Math.sin(elapsedTime) * 0.05;
                    break;
            }
            currentVrm.update(deltaTime);
        }

        function animate() {
            requestAnimationFrame(animate);
            updateAnimation(clock.getDelta(), clock.getElapsedTime());
            renderer.render(scene, camera);
        }
        animate();

        // ==========================================
        // 4. チャットUI ＆ Gemini API 連携
        // ==========================================
        const chatHistoryDiv = document.getElementById('chat-history');
        const quickRepliesDiv = document.getElementById('quick-replies');
        const chatInput = document.getElementById('chat-input');
        const sendBtn = document.getElementById('send-btn');

        function renderHistory() {
            chatHistoryDiv.innerHTML = '';
            chatHistory.forEach(msg => {
                const div = document.createElement('div');
                div.className = `msg ${msg.role === 'user' ? 'user' : 'bot'}`;
                div.textContent = msg.content;
                chatHistoryDiv.appendChild(div);
            });
            chatHistoryDiv.scrollTop = chatHistoryDiv.scrollHeight;
        }

        function triggerAvatarAction(emotionLabel, gestureLabel) {
            if (!currentVrm) return;
            currentGesture = gestureLabel || 'listening';
            gestureTimer = 3.0; // 3秒間リアクションを維持

            const expressions = currentVrm.expressionManager;
            expressions.setValue('happy', 0);
            expressions.setValue('angry', 0);
            expressions.setValue('sad', 0);
            expressions.setValue('neutral', 0);

            if (emotionLabel === 'joy') expressions.setValue('happy', 1.0);
            else if (emotionLabel === 'angry') expressions.setValue('angry', 1.0);
            else if (emotionLabel === 'sorrow') expressions.setValue('sad', 1.0);
            else expressions.setValue('neutral', 1.0);
        }

        async function callGeminiAPI(userText) {
            const apiKey = apiKeyInput.value.trim();
            if (!apiKey) return alert('設定(⚙️)からGemini APIキーを入力してください。');
            if (!characterSettings) return alert('設定(⚙️)からキャラ設定JSONを読み込んでください。');

            // UI更新
            chatHistory.push({ role: 'user', content: userText });
            renderHistory();
            chatInput.value = '';
            quickRepliesDiv.innerHTML = '';
            
            // 短期記憶（直近6往復）を抽出
            const recentHistory = chatHistory.slice(-12).map(msg => ({
                role: msg.role === 'user' ? 'user' : 'model',
                parts: [{ text: msg.content }]
            }));

            // APIリクエストの構築
            const systemPrompt = `
あなたは以下の設定を持つ3DヒューマノイドAIです。
必ず指定されたJSONフォーマットのみで返答してください。
【キャラ設定】
${JSON.stringify(characterSettings)}
【現在の長期記憶・バイアス情報】
${JSON.stringify(relationMemory)}

【出力JSONスキーマ】
{
  "speech_text": "実際に発話するテキスト",
  "quick_replies": ["返答候補1", "返答候補2", "返答候補3"],
  "emotion": "joy, angry, sorrow, neutralのいずれか",
  "gesture": "nod, shake_head, joy, angry, sorrow, present, listeningのいずれか"
}
`;
            try {
                const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${apiKey}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        systemInstruction: { parts: [{ text: systemPrompt }] },
                        contents: recentHistory,
                        generationConfig: { responseMimeType: "application/json" }
                    })
                });

                if (!response.ok) throw new Error('API通信エラーが発生しました');
                const data = await response.json();
                const resultJsonStr = data.candidates[0].content.parts[0].text;
                const result = JSON.parse(resultJsonStr);

                // アバターのリアクションと発話
                triggerAvatarAction(result.emotion, result.gesture);
                chatHistory.push({ role: 'bot', content: result.speech_text });
                localStorage.setItem('vrm_chatHistory', JSON.stringify(chatHistory));
                renderHistory();

                // クイックリプライの生成
                if (result.quick_replies) {
                    result.quick_replies.forEach(text => {
                        const btn = document.createElement('button');
                        btn.className = 'qr-btn';
                        btn.textContent = text;
                        btn.onclick = () => callGeminiAPI(text);
                        quickRepliesDiv.appendChild(btn);
                    });
                }
            } catch (error) {
                console.error(error);
                alert('APIの呼び出しに失敗しました。');
            }
        }

        sendBtn.addEventListener('click', () => {
            const text = chatInput.value.trim();
            if (text) callGeminiAPI(text);
        });
        chatInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendBtn.click();
        });

        // ==========================================
        // 5. エクスポート・システム管理
        // ==========================================
        window.toggleSettings = () => {
            const panel = document.getElementById('settings-panel');
            panel.style.display = panel.style.display === 'block' ? 'none' : 'block';
        };

        window.exportData = () => {
            const logText = chatHistory.map(m => `${m.role === 'user' ? 'あなた' : 'AI'}: ${m.content}`).join('\n\n');
            const dataToExport = {
                log: logText,
                memory: relationMemory,
                settings: characterSettings
            };
            const blob = new Blob([JSON.stringify(dataToExport, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'vrm_ai_backup.json';
            a.click();
            URL.revokeObjectURL(url);
        };

        window.clearMemory = () => {
            if(confirm('本当に記憶とログをリセットしますか？')) {
                localStorage.removeItem('vrm_chatHistory');
                localStorage.removeItem('vrm_relationMemory');
                chatHistory = [];
                relationMemory = {};
                renderHistory();
                quickRepliesDiv.innerHTML = '';
            }
        };

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        // 初期描画
        renderHistory();
    </script>
</body>
</html>
